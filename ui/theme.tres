[gd_resource type="Theme" load_steps=12 format=3]

; Midsummer Slots — shared UI theme (Tier 1).
; Primary Button = default Button (warm amber). Secondary = "SecondaryButton" type
; variation (dark/outline). PanelContainer = dark navy. Label variations: TitleLabel
; (gold 24), CaptionLabel (muted 13), CurrencyLabel (gold 20).

